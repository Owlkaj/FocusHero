<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel - FocusHero</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = { theme: { extend: { colors: { retroBlue: '#00f0ff', retroRed: '#ff2a5f', retroGold: '#ffd700' }, fontFamily: { mono: ['"Courier New"', 'monospace'] } } } }
    </script>
    <style>
        @keyframes blob { 0% { transform: translate(0px, 0px) scale(1); } 33% { transform: translate(30px, -50px) scale(1.1); } 66% { transform: translate(-20px, 20px) scale(0.9); } 100% { transform: translate(0px, 0px) scale(1); } }
        .animate-blob { animation: blob 10s infinite alternate ease-in-out; } .animation-delay-2000 { animation-delay: 2s; }
        .bg-grid-pattern { background-size: 40px 40px; background-image: linear-gradient(to right, rgba(255, 255, 255, 0.03) 1px, transparent 1px), linear-gradient(to bottom, rgba(255, 255, 255, 0.03) 1px, transparent 1px); }
    </style>
</head>
<body class="bg-[#0f172a] text-white font-mono p-6 min-h-screen relative z-0 overflow-x-hidden">
    <div class="fixed inset-0 w-full h-full z-[-1]">
        <div class="absolute inset-0 bg-grid-pattern"></div>
        <div class="absolute top-[-10%] left-[-10%] w-[500px] h-[500px] bg-red-600/10 rounded-full mix-blend-screen filter blur-[100px] animate-blob"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[500px] h-[500px] bg-blue-600/10 rounded-full mix-blend-screen filter blur-[100px] animate-blob animation-delay-2000"></div>
    </div>

    <nav class="flex justify-between items-center border-b border-retroRed/30 pb-4 mb-8">
        <h1 class="text-2xl font-bold text-retroRed drop-shadow-[0_0_8px_rgba(255,42,95,0.6)] tracking-widest">>> ADMIN_COMMAND_CENTER</h1>
        <a href="/dashboard" class="text-gray-400 hover:text-white transition-colors text-sm tracking-widest"><< BACK TO DASHBOARD</a>
    </nav>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-slate-900/60 backdrop-blur-md border border-retroRed/30 p-6 rounded-xl text-center shadow-[inset_0_0_15px_rgba(255,42,95,0.05),0_0_15px_rgba(255,42,95,0.1)] relative overflow-hidden group hover:border-retroRed/50 transition-colors">
            <div class="absolute top-0 right-0 w-16 h-16 bg-retroRed opacity-5 group-hover:opacity-10 transition-opacity rounded-bl-full"></div>
            <h2 class="text-gray-400 text-xs tracking-widest mb-2">TOTAL_REGISTERED_USERS</h2>
            <p class="text-4xl font-bold text-white drop-shadow-[0_0_5px_rgba(255,255,255,0.5)]"><%= stats.total_users %></p>
        </div>
        <div class="bg-slate-900/60 backdrop-blur-md border border-retroBlue/30 p-6 rounded-xl text-center shadow-[inset_0_0_15px_rgba(0,240,255,0.05),0_0_15px_rgba(0,240,255,0.1)] relative overflow-hidden group hover:border-retroBlue/50 transition-colors">
            <div class="absolute top-0 right-0 w-16 h-16 bg-retroBlue opacity-5 group-hover:opacity-10 transition-opacity rounded-bl-full"></div>
            <h2 class="text-gray-400 text-xs tracking-widest mb-2">TOTAL_QUESTS_CREATED</h2>
            <p class="text-4xl font-bold text-white drop-shadow-[0_0_5px_rgba(255,255,255,0.5)]"><%= stats.total_habits %></p>
        </div>
    </div>

    <div class="mb-6 text-right">
        <a href="/admin/habits" class="inline-block bg-retroBlue/10 text-retroBlue border border-retroBlue hover:bg-retroBlue hover:text-black font-bold py-2 px-6 rounded transition-all duration-300 text-sm tracking-wider shadow-[0_0_10px_rgba(0,240,255,0.2)]">
            [ GLOBAL_QUEST_MODERATION ]
        </a>
    </div>

    <div class="bg-slate-900/70 backdrop-blur-md border border-slate-700 rounded-xl overflow-hidden shadow-2xl">
        <div class="p-4 bg-slate-800/80 border-b border-slate-700">
            <h2 class="font-bold text-retroRed tracking-widest text-sm">PLAYER_DATABASE</h2>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse whitespace-nowrap">
                <thead>
                    <tr class="bg-slate-800/50 text-gray-400 text-xs tracking-wider">
                        <th class="p-4 border-b border-slate-700 text-center">USERNAME</th>
                        <th class="p-4 border-b border-slate-700 text-center">EMAIL</th>
                        <th class="p-4 border-b border-slate-700 text-center">ROLE</th>
                        <th class="p-4 border-b border-slate-700 text-center">XP</th>
                        <th class="p-4 border-b border-slate-700 text-center">ACTIONS</th>
                    </tr>
                </thead>
                <tbody class="text-sm">
                    <% users.forEach(user => { %>
                    <tr class="hover:bg-slate-800/80 border-b border-slate-700/50 transition-colors">
                        <td class="p-4 text-center font-bold text-white"><%= user.username %></td>
                        <td class="p-4 text-center text-gray-400"><%= user.email %></td>
                        <td class="p-4 text-center">
                            <span class="<%= user.role === 'admin' ? 'bg-red-500/10 text-retroRed border-retroRed' : 'bg-green-500/10 text-green-400 border-green-500/50' %> border px-2 py-0.5 rounded text-xs tracking-widest">
                                <%= user.role.toUpperCase() %>
                            </span>
                        </td>
                        <td class="p-4 text-center text-retroGold font-bold"><%= user.total_points %></td>
                        <td class="p-4 flex justify-center items-center gap-3">
                            <a href="/admin/user-habits/<%= user.id %>" class="bg-green-500/10 text-green-400 border border-green-500 hover:bg-green-500 hover:text-black px-3 py-1 rounded text-xs font-bold transition-all">QUESTS</a>
                            <a href="/admin/edit-user/<%= user.id %>" class="bg-retroBlue/10 text-retroBlue border border-retroBlue hover:bg-retroBlue hover:text-black px-3 py-1 rounded text-xs font-bold transition-all">EDIT</a>
                            
                            <% if(user.role !== 'admin') { %>
                            <form action="/admin/delete-user/<%= user.id %>" method="POST" onsubmit="return confirm('Hapus player ini selamanya?')" class="inline">
                                <button class="bg-retroRed/10 text-retroRed border border-retroRed hover:bg-retroRed hover:text-white px-3 py-1 rounded text-xs font-bold transition-all">BAN</button>
                            </form>
                            <% } else { %>
                                <span class="text-gray-600 italic text-xs px-3 py-1">IMMUNE</span>
                            <% } %>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>