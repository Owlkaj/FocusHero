<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8"><title>Quest Archive - FocusHero</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>tailwind.config = { theme: { extend: { colors: { retroBlue: '#00f0ff', retroPurple: '#b026ff' }, fontFamily: { mono: ['"Courier New"', 'monospace'] } } } }</script>
    <style>
        @keyframes blob { 0% { transform: translate(0px, 0px) scale(1); } 33% { transform: translate(30px, -50px) scale(1.1); } 66% { transform: translate(-20px, 20px) scale(0.9); } 100% { transform: translate(0px, 0px) scale(1); } }
        .animate-blob { animation: blob 10s infinite alternate ease-in-out; } .animation-delay-2000 { animation-delay: 2s; }
        .bg-grid-pattern { background-size: 40px 40px; background-image: linear-gradient(to right, rgba(255, 255, 255, 0.03) 1px, transparent 1px), linear-gradient(to bottom, rgba(255, 255, 255, 0.03) 1px, transparent 1px); }
    </style>
</head>
<body class="bg-[#0f172a] text-white font-mono p-6 min-h-screen relative z-0 overflow-x-hidden">
    <div class="fixed inset-0 w-full h-full z-[-1]">
        <div class="absolute inset-0 bg-grid-pattern"></div>
        <div class="absolute top-[20%] right-[-10%] w-[400px] h-[400px] bg-purple-600/20 rounded-full mix-blend-screen filter blur-[100px] animate-blob animation-delay-2000"></div>
    </div>

    <nav class="max-w-3xl mx-auto flex justify-between items-center border-b border-retroPurple/30 pb-4 mb-8">
        <h1 class="text-2xl font-bold text-retroPurple drop-shadow-[0_0_8px_rgba(176,38,255,0.6)] tracking-widest">>> QUEST_ARCHIVE_LOGS</h1>
        <a href="/dashboard" class="text-gray-400 hover:text-white transition-colors text-sm tracking-widest"><< BACK TO DASHBOARD</a>
    </nav>

    <div class="max-w-3xl mx-auto bg-slate-900/70 backdrop-blur-md border border-slate-700 p-8 rounded-xl shadow-[0_0_30px_rgba(0,0,0,0.5)]">
        
        <p class="text-gray-400 mb-6 text-sm tracking-widest border-l-4 border-retroPurple pl-3 py-1">
            Menampilkan 50 rekam jejak penyelesaian quest terakhir dari ID: <span class="text-white font-bold"><%= user.username %></span>
        </p>

        <% if (logs.length > 0) { %>
            <div class="space-y-3">
                <% logs.forEach(log => { %>
                    <div class="bg-slate-800/50 border border-slate-700 p-4 rounded flex justify-between items-center hover:border-retroPurple/50 hover:bg-slate-800 transition-colors">
                        <div class="flex items-center gap-4">
                            <span class="text-retroPurple text-xl drop-shadow-[0_0_5px_rgba(176,38,255,0.5)]">✓</span>
                            <span class="text-white font-bold tracking-wide"><%= log.title %></span>
                        </div>
                        <div class="text-right">
                            <span class="block text-xs text-gray-500 tracking-widest">DATE_COMPLETED</span>
                            <span class="text-gray-300 text-sm font-bold bg-black/40 px-2 py-1 rounded">
                                <%= new Date(log.date_completed).toLocaleDateString('id-ID', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }) %>
                            </span>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="text-center py-12 border-2 border-dashed border-slate-700 rounded-lg">
                <p class="text-gray-500 italic tracking-widest">NO_RECORDS_FOUND</p>
                <p class="text-xs text-gray-600 mt-2">Selesaikan sebuah quest di Dashboard untuk mulai mencatat sejarahmu.</p>
            </div>
        <% } %>
    </div>
</body>
</html>