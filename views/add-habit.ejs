<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tambah Quest - FocusHero</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>tailwind.config = { theme: { extend: { colors: { retroBlue: '#00f0ff' }, fontFamily: { mono: ['"Courier New"', 'monospace'] } } } }</script>
    <style>
        @keyframes blob { 0% { transform: translate(0px, 0px) scale(1); } 33% { transform: translate(30px, -50px) scale(1.1); } 66% { transform: translate(-20px, 20px) scale(0.9); } 100% { transform: translate(0px, 0px) scale(1); } }
        .animate-blob { animation: blob 10s infinite alternate ease-in-out; } .animation-delay-2000 { animation-delay: 2s; }
        .bg-grid-pattern { background-size: 40px 40px; background-image: linear-gradient(to right, rgba(255, 255, 255, 0.03) 1px, transparent 1px), linear-gradient(to bottom, rgba(255, 255, 255, 0.03) 1px, transparent 1px); }
    </style>
</head>
<body class="bg-[#0f172a] text-white font-mono min-h-screen flex flex-col items-center justify-center p-6 relative z-0 overflow-hidden">
    <div class="fixed inset-0 w-full h-full z-[-1]">
        <div class="absolute inset-0 bg-grid-pattern"></div>
        <div class="absolute top-[20%] right-[10%] w-[500px] h-[500px] bg-cyan-500/20 rounded-full mix-blend-screen filter blur-[100px] animate-blob"></div>
    </div>

    <div class="bg-slate-900/70 backdrop-blur-md border border-slate-700 p-8 rounded-xl w-full max-w-lg shadow-[0_0_30px_rgba(0,0,0,0.5)]">
        <h1 class="text-2xl font-bold text-retroBlue mb-8 drop-shadow-[0_0_8px_rgba(0,240,255,0.6)] tracking-widest">>> CREATE_NEW_QUEST</h1>
        
        <form action="/add-habit" method="POST" class="space-y-6">
            <div>
                <label class="block text-xs text-gray-400 tracking-widest mb-2">QUEST TITLE (e.g., Baca Buku)</label>
                <input type="text" name="title" required class="w-full bg-slate-800/50 border border-slate-600 text-white p-3 rounded focus:border-retroBlue focus:bg-slate-800 outline-none transition-all">
            </div>
            <div>
                <label class="block text-xs text-gray-400 tracking-widest mb-2">DESCRIPTION (Optional)</label>
                <textarea name="description" rows="3" class="w-full bg-slate-800/50 border border-slate-600 text-white p-3 rounded focus:border-retroBlue focus:bg-slate-800 outline-none transition-all"></textarea>
            </div>
            <div class="flex gap-4 pt-4">
                <a href="/dashboard" class="flex-1 text-center bg-transparent border border-slate-600 text-gray-300 font-bold py-2.5 rounded hover:bg-slate-800 transition-colors tracking-widest">CANCEL</a>
                <button type="submit" class="flex-1 bg-retroBlue/10 text-retroBlue border border-retroBlue hover:bg-retroBlue hover:text-black font-bold py-2.5 rounded transition-all duration-300 tracking-wider shadow-[0_0_10px_rgba(0,240,255,0.3)]">SAVE QUEST</button>
            </div>
        </form>
    </div>
</body>
</html>