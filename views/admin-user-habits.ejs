<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8"><title>Manage Tasks: <%= targetUser.username %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>tailwind.config = { theme: { extend: { colors: { retroBlue: '#00f0ff', retroRed: '#ff2a5f' }, fontFamily: { mono: ['"Courier New"', 'monospace'] } } } }</script>
    <style>
        .bg-grid-pattern { background-size: 40px 40px; background-image: linear-gradient(to right, rgba(255, 255, 255, 0.03) 1px, transparent 1px), linear-gradient(to bottom, rgba(255, 255, 255, 0.03) 1px, transparent 1px); }
    </style>
</head>
<body class="bg-[#0f172a] text-white font-mono p-6 min-h-screen relative z-0 overflow-x-hidden">
    <div class="fixed inset-0 w-full h-full z-[-1] bg-grid-pattern"></div>

    <nav class="flex justify-between items-center border-b border-retroBlue/30 pb-4 mb-8">
        <h1 class="text-xl font-bold text-retroBlue tracking-widest drop-shadow-[0_0_8px_rgba(0,240,255,0.6)]">>> MANAGE_TASKS: <span class="text-white"><%= targetUser.username.toUpperCase() %></span></h1>
        <a href="/admin" class="text-gray-400 hover:text-white transition-colors tracking-widest text-sm"><< BACK TO ADMIN</a>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="bg-slate-900/70 backdrop-blur-md border border-slate-700 p-6 rounded-xl h-fit shadow-xl">
            <h2 class="text-retroBlue font-bold mb-6 tracking-widest border-b border-slate-700 pb-2">+ ASSIGN NEW QUEST</h2>
            <form action="/admin/user-habits/<%= targetUser.id %>/add" method="POST" class="space-y-4 text-sm">
                <input type="text" name="title" placeholder="Quest Name" required class="w-full bg-slate-800/50 border border-slate-600 p-3 rounded outline-none focus:border-retroBlue text-white">
                <textarea name="description" placeholder="Description (Optional)" class="w-full bg-slate-800/50 border border-slate-600 p-3 rounded outline-none focus:border-retroBlue text-white h-24"></textarea>
                <button class="w-full bg-retroBlue/10 text-retroBlue border border-retroBlue hover:bg-retroBlue hover:text-black font-bold py-3 rounded transition-all duration-300 tracking-wider">FORCE_ASSIGN</button>
            </form>
        </div>

        <div class="lg:col-span-2 bg-slate-900/70 backdrop-blur-md border border-slate-700 p-6 rounded-xl shadow-xl">
            <h2 class="text-gray-400 font-bold mb-6 tracking-widest border-b border-slate-700 pb-2">ACTIVE_QUESTS_LIST</h2>
            <div class="space-y-4">
                <% if(habits.length > 0) { %>
                    <% habits.forEach(habit => { %>
                        <div class="bg-slate-800/50 border border-slate-700 p-5 rounded-lg flex justify-between items-center hover:bg-slate-800 transition-colors">
                            <div>
                                <p class="font-bold text-white tracking-wide"><%= habit.title %></p>
                                <p class="text-sm text-gray-500 mt-1"><%= habit.description %></p>
                            </div>
                            <form action="/admin/delete-habit/<%= habit.id %>" method="POST">
                                <button class="text-retroRed text-xs border border-retroRed/50 hover:bg-retroRed hover:text-white px-3 py-1.5 rounded transition-colors tracking-widest">DELETE</button>
                            </form>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="text-center py-8 border-2 border-dashed border-slate-700 rounded-lg">
                        <p class="text-gray-500 italic tracking-widest">Player ini tidak memiliki quest aktif.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>