<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8"><title>Quest Moderation - Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>tailwind.config = { theme: { extend: { colors: { retroBlue: '#00f0ff', retroRed: '#ff2a5f', retroGold: '#ffd700' }, fontFamily: { mono: ['"Courier New"', 'monospace'] } } } }</script>
    <style>
        .bg-grid-pattern { background-size: 40px 40px; background-image: linear-gradient(to right, rgba(255, 255, 255, 0.03) 1px, transparent 1px), linear-gradient(to bottom, rgba(255, 255, 255, 0.03) 1px, transparent 1px); }
    </style>
</head>
<body class="bg-[#0f172a] text-white font-mono p-6 min-h-screen relative z-0 overflow-x-hidden">
    <div class="fixed inset-0 w-full h-full z-[-1] bg-grid-pattern"></div>

    <nav class="flex justify-between items-center border-b border-retroRed/30 pb-4 mb-8">
        <h1 class="text-2xl font-bold text-retroRed tracking-widest drop-shadow-[0_0_8px_rgba(255,42,95,0.6)]">>> GLOBAL_QUEST_MODERATION</h1>
        <a href="/admin" class="text-gray-400 hover:text-white transition-colors tracking-widest text-sm"><< BACK TO ADMIN</a>
    </nav>

    <div class="bg-slate-900/70 backdrop-blur-md border border-slate-700 rounded-xl overflow-hidden shadow-2xl">
        <div class="overflow-x-auto">
            <table class="w-full text-left whitespace-nowrap">
                <thead class="bg-slate-800/80 text-gray-400 text-xs tracking-wider border-b border-slate-700">
                    <tr>
                        <th class="p-4 text-center">PLAYER</th>
                        <th class="p-4">QUEST_TITLE</th>
                        <th class="p-4 text-center">STREAK</th>
                        <th class="p-4 text-center">ACTION</th>
                    </tr>
                </thead>
                <tbody class="text-sm">
                    <% habits.forEach(habit => { %>
                    <tr class="border-b border-slate-700/50 hover:bg-slate-800/50 transition-colors">
                        <td class="p-4 font-bold text-retroBlue text-center"><%= habit.username %></td>
                        <td class="p-4">
                            <p class="text-white font-bold tracking-wide"><%= habit.title %></p>
                            <p class="text-xs text-gray-500 mt-1"><%= habit.description %></p>
                        </td>
                        <td class="p-4 text-retroGold text-center"><%= habit.streak_count %>🔥</td>
                        <td class="p-4 text-center">
                            <form action="/admin/delete-habit/<%= habit.id %>" method="POST" onsubmit="return confirm('Hapus quest ini dari database?')">
                                <button class="text-retroRed hover:text-white hover:bg-retroRed border border-transparent hover:border-retroRed px-3 py-1 rounded text-xs transition-colors tracking-widest">DELETE</button>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>